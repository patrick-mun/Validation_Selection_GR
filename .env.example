# Génome Réunion Validation Pipeline — exemple de configuration
# Copier ce fichier en .env avant le premier docker compose up.
# Ne jamais mettre de vrai secret ou donnée personnelle dans Git.

# Compte PostgreSQL de développement local/Docker.
# À remplacer avant tout déploiement serveur.
POSTGRES_DB=genorun_validation
POSTGRES_USER=genorun
POSTGRES_PASSWORD=change-me-local-dev
POSTGRES_PORT=5432

# URL PostgreSQL officielle du projet.
# En Docker, l'hôte est genorun-db. En local hors Docker, utiliser plutôt localhost.
GENORUN_DATABASE_URL=postgresql+psycopg://genorun:change-me-local-dev@genorun-db:5432/genorun_validation
GENORUN_ENABLE_DATABASE=true

# Secret Flask de développement. À remplacer avant déploiement.
GENORUN_SECRET_KEY=change-me-local-secret
GENORUN_APP_PORT=8000

# Mode worker :
# - local_popen : l’interface lance scripts/run_worker.py localement
# - external    : l’interface crée un job queued, pris en charge par scripts/run_worker_loop.py
GENORUN_WORKER_MODE=external
GENORUN_JOB_BACKEND=filesystem_plus_postgresql

# Stockage fichiers : les gros fichiers génétiques restent hors base.
GENORUN_RUNS_ROOT=/app/work/runs
GENORUN_INPUTS_ROOT=/app/data/inputs
GENORUN_OUTPUTS_ROOT=/app/results
GENORUN_REPORTS_ROOT=/app/reports
GENORUN_LOGS_ROOT=/app/logs
